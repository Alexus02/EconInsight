{
  "name": "econinsight-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:migrate": "wrangler d1 execute econinsight-db --file=./schema/uploaded-files.sql",
    "d1:migrate:bookings": "wrangler d1 execute econinsight-db --file=./schema/bookings.sql",
    "d1:migrate:all": "wrangler d1 execute econinsight-db --file=./schema/uploaded-files.sql && wrangler d1 execute econinsight-db --file=./schema/bookings.sql"
  },
  "devDependencies": {
    "wrangler": "^4.15.2"
  }
}
